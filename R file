```{r}
test_preds <- predict(final_fit_train, new_data = cc_test, type = "prob") %>%
  bind_cols(cc_test %>% select(CourseCompletion)) %>%
  mutate(
    include_completed = (1 - .pred_Completed) <= q_hat,
    include_not_completed = (1 - `.pred_Not Completed`) <= q_hat,
    pred_set = case_when(
      include_completed & include_not_completed ~ "{Completed, Not Completed}",
      include_completed ~ "{Completed}",
      include_not_completed ~ "{Not Completed}",
      TRUE ~ "{}"
    ),
    covered = case_when(
      CourseCompletion == "Completed" ~ include_completed,
      CourseCompletion == "Not Completed" ~ include_not_completed
    )
  )
