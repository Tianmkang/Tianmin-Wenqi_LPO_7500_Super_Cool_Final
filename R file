### Data
### a.Data Source/Data Access and Cleaning
```{r}
data <- read_csv("online_course_engagement_data.csv", show_col_types = FALSE) %>%
  mutate(CourseCompletion = factor(CourseCompletion,
                                  levels = c(0, 1),
                                  labels = c("Not Completed", "Completed"))) %>%
  mutate(CourseCompletion = fct_relevel(CourseCompletion, "Completed"))

```

### b. Train / Calibration / Test Split
```{r}
main_split <- initial_split(data, prop = 0.80, strata = CourseCompletion)
train_cal <- training(main_split)
cc_test   <- testing(main_split)

cal_split <- initial_split(train_cal, prop = 0.75, strata = CourseCompletion)
cc_train  <- training(cal_split)
cc_cal    <- testing(cal_split)

tibble(
  set = c("train", "calibration", "test"),
  n = c(nrow(cc_train), nrow(cc_cal), nrow(cc_test))
)
```

