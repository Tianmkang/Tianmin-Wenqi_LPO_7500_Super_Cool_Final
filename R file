```{r}
score_course_completion <- function(new_data,
                                    model_path = "artifacts/course_completion_model.rds") {
  
  required_cols <- c(
    "CourseCategory",
    "TimeSpentOnCourse",
    "NumberOfVideosWatched",
    "NumberOfQuizzesTaken",
    "QuizScores"
  )
  
  missing_cols <- setdiff(required_cols, names(new_data))
  
  if (length(missing_cols) > 0) {
    stop(paste("Missing required columns:", paste(missing_cols, collapse = ", ")))
  }
  
  model <- readRDS(model_path)
  
  prob_preds <- predict(model, new_data = new_data, type = "prob")
  class_preds <- predict(model, new_data = new_data, type = "class")
  
  bind_cols(new_data, prob_preds, class_preds)
}
```

