### Model Development
### a. Preprocessing Pipeline

```{r}
cc_rec <- recipe(
  CourseCompletion ~
    CourseCategory +
    TimeSpentOnCourse +
    NumberOfVideosWatched +
    NumberOfQuizzesTaken +
    QuizScores,
  data = cc_train
) %>%
  step_unknown(all_nominal_predictors()) %>%
  step_other(all_nominal_predictors(), threshold = 0.05) %>%
  step_dummy(all_nominal_predictors()) %>%
  step_impute_median(all_numeric_predictors()) %>%
  step_zv(all_predictors()) %>%
  step_normalize(all_numeric_predictors())
```

### b. Elastic Net + Bayesian Optimization

```{r}
enet_mod <- logistic_reg(
  penalty = tune(),
  mixture = tune()
) %>%
  set_engine("glmnet")
```

```{r}
enet_wf <- workflow() %>%
  add_recipe(cc_rec) %>%
  add_model(enet_mod)
```

```{r}
cc_folds <- vfold_cv(cc_train, v = 10, strata = CourseCompletion)
```

```{r}
enet_grid <- grid_space_filling(
  penalty(),
  mixture(),
  size = 10
)
```

```{r}
dir.create("artifacts", showWarnings = FALSE)

fit_model <- TRUE

if (fit_model) {

  enet_tune <- tune_bayes(
    enet_wf,
    resamples = cc_folds,
    initial = 10,
    iter = 15,
    metrics = metric_set(roc_auc, accuracy),
    control = control_bayes(save_pred = TRUE, verbose = TRUE)
  )

  save(enet_tune, file = "artifacts/enet_tune_bayes.Rdata")

} else {
  load("artifacts/enet_tune_bayes.Rdata")
}
```

