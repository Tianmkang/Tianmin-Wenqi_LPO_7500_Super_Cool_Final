### Conformal Prediction Sets

```{r}
final_fit_train <- fit(final_wf, data = cc_train)

cal_preds <- predict(final_fit_train, new_data = cc_cal, type = "prob") %>%
  bind_cols(cc_cal %>% select(CourseCompletion))

cal_scores <- cal_preds %>%
  mutate(
    score = if_else(
      CourseCompletion == "Completed",
      1 - .pred_Completed,
      1 - `.pred_Not Completed`
    )
  )
```

```{r}
alpha <- 0.10
n <- nrow(cal_scores)

q_level <- min(ceiling((n + 1) * (1 - alpha)) / n, 1)
q_hat <- quantile(cal_scores$score, probs = q_level)

cal_scores %>%
  ggplot(aes(x = score)) +
  geom_histogram(bins = 30, fill = "steelblue", color = "white") +
  geom_vline(xintercept = q_hat, color = "red", linetype = "dashed") +
  labs(
    title = "Calibration Nonconformity Scores",
    x = "1 - predicted probability of the true class",
    y = "Count"
  )
```

